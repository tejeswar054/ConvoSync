# ========================================
# ConvoSync Backend Configuration
# ========================================

# ✅ LOCAL DEVELOPMENT (Use as-is for localhost)
# ========================================
MONGODB_URI=mongodb://localhost:27017/convosync
JWT_SECRET=dev_secret_key_123
FRONTEND_URL=http://localhost:5173

# ========================================
# 🚀 PRODUCTION DEPLOYMENT (Railway)
# ========================================
# IMPORTANT: Set these 3 variables on Railway Dashboard
# Copy the values EXACTLY from your deployed services
#
# 1. MONGODB_URI: Get from MongoDB Atlas cluster
#    Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/convosync
#
# 2. JWT_SECRET: Generate a random strong string (use: https://uuidgenerator.net/)
#    Example: a7f3b9e2c1d5f8g4h6i9j2k5l8m1n4o7
#
# 3. FRONTEND_URL: Your Vercel/deployed frontend URL (CRITICAL FOR CORS!)
#    Example: https://convosync.vercel.app
#
# ⚠️ WITHOUT FRONTEND_URL, CORS will fail and users cannot use the app!
#
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/convosync
# JWT_SECRET=generate_a_strong_random_string_here
# FRONTEND_URL=https://your-frontend-domain.vercel.app
